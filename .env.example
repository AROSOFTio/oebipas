# ==================================
# OEBIPAS Environment Variables
# Copy this file to .env and update values before deploying
# ==================================

# --- Backend Configuration ---
PORT=5000
NODE_ENV=production

# --- Database Setup (MySQL) ---
DB_HOST=db
DB_USER=oebipas_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=oebipas
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# --- JWT Auth ---
# IMPORTANT: Generate a strong random secret in production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING
JWT_EXPIRES_IN=24h

# --- App Settings ---
APP_NAME="OEBIPAS"
COMPANY_NAME="Uganda Electricity Distribution Company Limited"
FRONTEND_URL=http://localhost:8083
BACKEND_PUBLIC_URL=http://localhost:5000
PESAPAL_ENV=sandbox
PESAPAL_BASE_URL=
PESAPAL_CONSUMER_KEY=CHANGE_THIS_PESAPAL_CONSUMER_KEY
PESAPAL_CONSUMER_SECRET=CHANGE_THIS_PESAPAL_CONSUMER_SECRET
PESAPAL_CURRENCY=UGX
PESAPAL_COUNTRY_CODE=UG
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_THIS_SMTP_USER
SMTP_PASS=CHANGE_THIS_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@oebipas.arosoft.io
SMTP_FROM_NAME=UEDCL OEBIPAS
AFRICASTALKING_USERNAME=CHANGE_THIS_AT_USERNAME
AFRICASTALKING_API_KEY=CHANGE_THIS_AT_API_KEY
AFRICASTALKING_SENDER_ID=UEDCL
