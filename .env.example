# ==================================
# OEBIPAS Environment Variables
# Copy this file to .env and update values before deploying
# ==================================

# --- Backend Configuration ---
PORT=5000
NODE_ENV=production

# --- Database Setup (MySQL) ---
DB_HOST=db
DB_USER=oebipas_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=oebipas
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# --- JWT Auth ---
# IMPORTANT: Generate a strong random secret in production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING
JWT_EXPIRES_IN=24h

# --- App Settings ---
APP_NAME="OEBIPAS"
COMPANY_NAME="Uganda Electricity Distribution Company Limited"
